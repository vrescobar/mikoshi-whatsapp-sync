# Database connection (use libpq URI form)
DATABASE_URL=postgresql://mikoshi:secret@localhost:5432/mikoshi

# Directory where the macOS pipeline rsyncs exports to
EXPORTS_DIR=/home/mikoshi/whatsapp_exports

# Permanent media store. Attachments are moved out of EXPORTS_DIR/attachments
# into here once ingested, named by sha256.
MEDIA_STORE=/var/lib/mikoshi/media

# Path to schema.json (copied/synced from the macOS pipeline)
SCHEMA_PATH=/opt/mikoshi/whatsapp_export/schema.json

# Watch-mode interval in seconds
WATCH_INTERVAL=300
